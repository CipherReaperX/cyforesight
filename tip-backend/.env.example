# Application
NODE_ENV=development
PORT=9999
LOG_LEVEL=info

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tip_db

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_min_32_chars
JWT_EXPIRY=24h

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:3001,http://localhost:4173

# External APIs (Optional)
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
SHODAN_API_KEY=

# Features
FEATURE_ML_SCORING=true
FEATURE_AUTO_ENRICHMENT=true
