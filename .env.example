# Copy this file to .env and fill in real values before running docker-compose

# PostgreSQL password (used by db service and backend DATABASE_URL)
POSTGRES_PASSWORD=change_me_strong_password

# JWT signing secret — minimum 32 characters, random string
JWT_SECRET=replace_with_a_random_64_char_string

# CORS allowed origin (your frontend URL in production)
CORS_ORIGIN=http://localhost:3000

# Optional threat-intel enrichment APIs
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
SHODAN_API_KEY=
