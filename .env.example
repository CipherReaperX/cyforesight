# Copy this file to .env to override docker-compose defaults.
# Without .env the docker-compose runs with built-in dev defaults — fine for local dev.
# For production deployments, set all values here with strong random strings.

# PostgreSQL password
POSTGRES_PASSWORD=cyforesight_dev_pass

# JWT signing secret — use a long random string in production
JWT_SECRET=cyforesight_dev_jwt_secret_change_in_production

# CORS allowed origin (your frontend URL in production)
CORS_ORIGIN=http://localhost:3000

# Optional threat-intel enrichment APIs
VIRUSTOTAL_API_KEY=
ABUSEIPDB_API_KEY=
SHODAN_API_KEY=
