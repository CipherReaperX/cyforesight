import { useParams, Link } from 'react-router-dom'
import { ArrowLeft, Copy, Download, Shield, Activity, AlertTriangle, Globe, FileText } from 'lucide-react'
import { Card, CardHeader, CardTitle, CardContent } from '@/components/ui/Card'
import { Button } from '@/components/ui/Button'
import { Badge } from '@/components/ui/Badge'
import { Progress } from '@/components/ui/Progress'
import { Table, TableHeader, TableBody, TableRow, TableHead, TableCell } from '@/components/ui/Table'
import { useIOC, useIOCEnrichment } from '@/hooks/useIOCs'
import { formatRelativeTime, formatDate } from '@/lib/utils'

export default function IOCDetail() {
  const { iocId } = useParams<{ iocId: string }>()
  const { data: ioc, isLoading } = useIOC(iocId!)
  const { data: enrichment } = useIOCEnrichment(iocId!)

  if (isLoading) {
    return <div className="text-slate-400">Loading...</div>
  }

  if (!ioc) {
    return <div className="text-slate-400">IOC not found</div>
  }

  return (
    <div className="space-y-6">
      {/* Header */}
      <div className="flex items-center justify-between">
        <div className="flex items-center space-x-4">
          <Link to="/iocs">
            <Button variant="ghost" size="sm">
              <ArrowLeft className="mr-2 h-4 w-4" />
              Back
            </Button>
          </Link>
          <div>
            <div className="flex items-center space-x-3">
              <h1 className="text-2xl font-bold text-slate-100">{ioc.value}</h1>
              {   badgeVariant = ioc.severity === 'info' ? 'default' : ioc.severity; }<Badge variant={badgeVariant}>ioc.severity</Badge>
              <Badge>{ioc.type}</Badge>
            </div>
            <p className="mt-1 text-sm text-slate-400">
              First seen {formatRelativeTime(ioc.firstSeen)} • Last seen {formatRelativeTime(ioc.lastSeen)}
            </p>
          </div>
        </div>
        <div className="flex space-x-2">
          <Button variant="outline">
            <Copy className="mr-2 h-4 w-4" />
            Copy
          </Button>
          <Button variant="outline">
            <Download className="mr-2 h-4 w-4" />
            Export
          </Button>
          <Button variant="danger">Block</Button>
        </div>
      </div>

      {/* Overview Cards */}
      <div className="grid grid-cols-1 gap-6 md:grid-cols-4">
        <Card>
          <CardContent>
            <div className="flex items-center justify-between">
              <div>
                <p className="text-sm text-slate-400">Confidence</p>
                <p className="mt-2 text-2xl font-bold text-blue-500">{ioc.confidence}%</p>
              </div>
              <Shield className="h-8 w-8 text-blue-500" />
            </div>
            <Progress value={ioc.confidence} className="mt-3" />
          </CardContent>
        </Card>
        <Card>
          <CardContent>
            <div className="flex items-center justify-between">
              <div>
                <p className="text-sm text-slate-400">ML Score</p>
                <p className="mt-2 text-2xl font-bold text-purple-500">{ioc.mlScore}/100</p>
              </div>
              <Activity className="h-8 w-8 text-purple-500" />
            </div>
            <Progress value={ioc.mlScore} className="mt-3" barClassName="bg-purple-500" />
          </CardContent>
        </Card>
        <Card>
          <CardContent>
            <div className="flex items-center justify-between">
              <div>
                <p className="text-sm text-slate-400">Affected Assets</p>
                <p className="mt-2 text-2xl font-bold text-orange-500">{ioc.affectedAssets}</p>
              </div>
              <AlertTriangle className="h-8 w-8 text-orange-500" />
            </div>
          </CardContent>
        </Card>
        <Card>
          <CardContent>
            <div className="flex items-center justify-between">
              <div>
                <p className="text-sm text-slate-400">Sources</p>
                <p className="mt-2 text-2xl font-bold text-green-500">{ioc.sources.length}</p>
              </div>
              <Globe className="h-8 w-8 text-green-500" />
            </div>
          </CardContent>
        </Card>
      </div>

      <div className="grid grid-cols-1 gap-6 lg:grid-cols-3">
        {/* Main Details */}
        <div className="lg:col-span-2 space-y-6">
          {/* Enrichment Data */}
          {enrichment?.virusTotal && (
            <Card>
              <CardHeader>
                <CardTitle>VirusTotal Analysis</CardTitle>
              </CardHeader>
              <CardContent>
                <div className="space-y-4">
                  <div className="flex items-center justify-between">
                    <span className="text-slate-400">Detection Ratio</span>
                    <Badge variant={(() => { const sev = enrichment.virusTotal.positives > 0 ? 'danger' : 'success'; return sev === 'info' ? 'default' : sev; })()}>
                      {enrichment.virusTotal.detectionRatio}
                    </Badge>
                  </div>
                  <div>
                    <div className="mb-2 flex items-center justify-between text-sm">
                      <span className="text-slate-400">Detection Score</span>
                      <span className="text-slate-300">
                        {enrichment.virusTotal.positives} / {enrichment.virusTotal.total}
                      </span>
                    </div>
                    <Progress
                      value={(enrichment.virusTotal.positives / enrichment.virusTotal.total) * 100}
                      barClassName={enrichment.virusTotal.positives > 0 ? 'bg-red-500' : 'bg-green-500'}
                    />
                  </div>
                  <div className="max-h-40 overflow-y-auto">
                    <div className="space-y-1">
                      {enrichment.virusTotal.vendors.slice(0, 5).map((vendor) => (
                        <div key={vendor.name} className="flex items-center justify-between text-sm">
                          <span className="text-slate-400">{vendor.name}</span>
                          <Badge variant={(() => { const sev = vendor.result !== 'clean' ? 'danger' : 'success'; return sev === 'info' ? 'default' : sev; })()}>
                            {vendor.result}
                          </Badge>
                        </div>
                      ))}
                    </div>
                  </div>
                </div>
              </CardContent>
            </Card>
          )}

          {/* GeoIP Data */}
          {enrichment?.geo && (
            <Card>
              <CardHeader>
                <CardTitle>Geolocation Data</CardTitle>
              </CardHeader>
              <CardContent>
                <div className="grid grid-cols-2 gap-4">
                  <div>
                    <p className="text-sm text-slate-400">Country</p>
                    <p className="mt-1 font-semibold text-slate-100">{enrichment.geo.country}</p>
                  </div>
                  <div>
                    <p className="text-sm text-slate-400">City</p>
                    <p className="mt-1 font-semibold text-slate-100">{enrichment.geo.city}</p>
                  </div>
                  <div>
                    <p className="text-sm text-slate-400">Latitude</p>
                    <p className="mt-1 font-mono text-sm text-slate-300">{enrichment.geo.lat}</p>
                  </div>
                  <div>
                    <p className="text-sm text-slate-400">Longitude</p>
                    <p className="mt-1 font-mono text-sm text-slate-300">{enrichment.geo.lon}</p>
                  </div>
                </div>
              </CardContent>
            </Card>
          )}

          {/* Related IOCs */}
          <Card>
            <CardHeader>
              <CardTitle>Related IOCs</CardTitle>
            </CardHeader>
            <CardContent>
              <Table>
                <TableHeader>
                  <TableRow>
                    <TableHead>Value</TableHead>
                    <TableHead>Type</TableHead>
                    <TableHead>Severity</TableHead>
                    <TableHead>Confidence</TableHead>
                  </TableRow>
                </TableHeader>
                <TableBody>
                  <TableRow>
                    <td colSpan={4} className="text-center text-slate-400">
                      No related IOCs found
                    </td>
                  </TableRow>
                </TableBody>
              </Table>
            </CardContent>
          </Card>
        </div>

        {/* Sidebar */}
        <div className="space-y-6">
          {/* Details */}
          <Card>
            <CardHeader>
              <CardTitle>Details</CardTitle>
            </CardHeader>
            <CardContent>
              <div className="space-y-3">
                <div>
                  <p className="text-sm text-slate-400">Status</p>
                  <Badge variant={ioc.status === 'active' ? 'danger' : 'default'} className="mt-1">
                    {ioc.status}
                  </Badge>
                </div>
                <div>
                  <p className="text-sm text-slate-400">Created</p>
                  <p className="mt-1 text-sm text-slate-300">{formatDate(ioc.createdAt)}</p>
                </div>
                <div>
                  <p className="text-sm text-slate-400">Updated</p>
                  <p className="mt-1 text-sm text-slate-300">{formatDate(ioc.updatedAt)}</p>
                </div>
              </div>
            </CardContent>
          </Card>

          {/* Tags */}
          <Card>
            <CardHeader>
              <CardTitle>Tags</CardTitle>
            </CardHeader>
            <CardContent>
              <div className="flex flex-wrap gap-2">
                {ioc.tags.map((tag) => (
                  <Badge key={tag} variant="default">
                    {tag}
                  </Badge>
                ))}
              </div>
            </CardContent>
          </Card>

          {/* Sources */}
          <Card>
            <CardHeader>
              <CardTitle>Sources</CardTitle>
            </CardHeader>
            <CardContent>
              <div className="space-y-2">
                {ioc.sources.map((source) => (
                  <div key={source} className="flex items-center space-x-2">
                    <FileText className="h-4 w-4 text-slate-400" />
                    <span className="text-sm text-slate-300">{source}</span>
                  </div>
                ))}
              </div>
            </CardContent>
          </Card>

          {/* MITRE Techniques */}
          <Card>
            <CardHeader>
              <CardTitle>MITRE ATT&CK</CardTitle>
            </CardHeader>
            <CardContent>
              <div className="space-y-2">
                {ioc.mitreTechniques.map((technique) => (
                  <div key={technique} className="rounded border border-slate-700 bg-slate-800/50 p-2">
                    <span className="font-mono text-sm text-blue-400">{technique}</span>
                  </div>
                ))}
              </div>
            </CardContent>
          </Card>
        </div>
      </div>
    </div>
  )
}
